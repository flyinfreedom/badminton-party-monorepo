{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "badminton-party-liff-web": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/badminton-party-liff-web",
      "sourceRoot": "projects/badminton-party-liff-web/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "dist/cloudflare",
              "browser": ""
            },
            "browser": "projects/badminton-party-liff-web/src/main.ts",
            "tsConfig": "projects/badminton-party-liff-web/tsconfig.app.json",
            "polyfills": ["zone.js"],
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/badminton-party-liff-web/public"
              }
            ],
            "styles": ["projects/badminton-party-liff-web/src/styles.scss"],
            "allowedCommonJsDependencies": [
              "moment",
              "tiny-sha256"
            ]
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "projects/badminton-party-liff-web/src/environments/environment.ts",
                  "with": "projects/badminton-party-liff-web/src/environments/environment.prod.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2MB",
                  "maximumError": "5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "ssl": true,
            "port": 4201,
            "proxyConfig": "proxy.conf.js"
          },
          "configurations": {
            "production": {
              "buildTarget": "badminton-party-liff-web:build:production"
            },
            "development": {
              "buildTarget": "badminton-party-liff-web:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    },
    "badminton-party-sharedlibrary": {
      "projectType": "library",
      "root": "projects/badminton-party-sharedlibrary",
      "sourceRoot": "projects/badminton-party-sharedlibrary/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/badminton-party-sharedlibrary/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/badminton-party-sharedlibrary/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/badminton-party-sharedlibrary/tsconfig.spec.json"
          }
        }
      }
    }
  }
}
